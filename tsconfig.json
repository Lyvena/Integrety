{
    "compilerOptions": {
      "target": "ESNext",
      "useDefineForClassFields": true,
      "lib": [
        "DOM",
        "DOM.Iterable",
        "ESNext"
      ],
      "allowJs": true,
      "skipLibCheck": true,
      "esModuleInterop": false,
      "allowSyntheticDefaultImports": true,
      "strict": false,
      "forceConsistentCasingInFileNames": true,
      "module": "ESNext",
      "moduleResolution": "Node",
      "resolveJsonModule": true,
      "isolatedModules": false,
      "noEmit": true,
      "jsx": "react-jsx",
      "baseUrl": ".",
      "paths": {
        "brain": [
          "./src/brain"
        ],
        "types": [
          "./src/brain/data-contracts.ts"
        ],
        "components/*": [
          "./src/components/*"
        ],
        "pages/*": [
          "./src/pages/*"
        ],
        "app": [
          "./src/app"
        ],
        "@/*": [
          "./src/*"
        ],
        "@/hooks/*": [
          "./src/extensions/shadcn/hooks/*"
        ],
        "@/components/hooks/*": [
          "./src/extensions/shadcn/hooks/*"
        ],
        "@/components/ui/*": [
          "./src/extensions/shadcn/components/*"
        ],
      }
    },
    "include": [
      "env.d.ts",
      "src"
    ],
    "exclude": [
      "src/brain/**/*"
    ],
    "references": [
      {
        "path": "./tsconfig.node.json"
      }
    ],
    "ts-node": {
      "compilerOptions": {
        "module": "CommonJS"
      }
    }
  }